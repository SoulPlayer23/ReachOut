# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
APP_PORT=9000

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=reachout
DB_PASSWORD=reachout
DATABASE_URL=postgresql://reachout:reachout@db:5432/reachout

# ── Resume ─────────────────────────────────────────────────────────────────────
# Place your resume at ~/.reachout/resume.pdf on your host machine.
# The docker-compose mounts ~/.reachout to /app/userdata inside the container.
RESUME_PATH=/app/userdata/resume.pdf

# ── LLM — Ollama Cloud (default) ───────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_KEY=

# ── LLM — Local Ollama (run with: docker compose --profile local up) ───────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_API_KEY=

# ── LLM — Claude (Anthropic) ───────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=

# ── LLM — OpenAI-compatible (Groq, OpenAI, etc.) ──────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=llama-3.3-70b-versatile

# ── Job Search ─────────────────────────────────────────────────────────────────
SERPER_API_KEY=
# SERPAPI_KEY=   # alternative to Serper.dev

# ── Recruiter Finders ──────────────────────────────────────────────────────────
APOLLO_API_KEY=
HUNTER_API_KEY=
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ── Google OAuth — Gmail sending only ─────────────────────────────────────────
# Setup: console.cloud.google.com → New Project → Gmail API → OAuth credentials (Desktop app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback
